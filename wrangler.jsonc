{
  // Nur für lokale Preview (`npm run preview`). Das Deployment auf Webflow Cloud
  // verwaltet Worker-Konfiguration und Environment Variables selbst.
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "is24-webflow-sync",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-03-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  }
}
