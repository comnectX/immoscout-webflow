# ── Webflow ──────────────────────────────────────────────────────────────────
# Site-Token mit Scopes: CMS read/write, Assets read/write (bei SYNC_IMAGES=true)
WEBFLOW_API_TOKEN=
WEBFLOW_SITE_ID=
WEBFLOW_COLLECTION_ID=

# ── ImmoScout24 (OAuth 1.0a) ─────────────────────────────────────────────────
IS24_CONSUMER_KEY=
IS24_CONSUMER_SECRET=
IS24_ACCESS_TOKEN=
IS24_ACCESS_TOKEN_SECRET=
IS24_USERNAME=me
IS24_BASE_URL=https://rest.immobilienscout24.de/restapi/api
# "Homepage" oder "IS24" – abhängig von den API-Berechtigungen des Accounts
IS24_PUBLISH_CHANNEL=Homepage

# ── Absicherung ──────────────────────────────────────────────────────────────
# Langer Zufallswert; schützt /api/sync und /api/diagnostics (Bearer-Token)
SYNC_SECRET=
# Passwort für die Admin-Oberfläche unter /admin
ADMIN_PASSWORD=

# ── Sync-Verhalten ───────────────────────────────────────────────────────────
DRY_RUN=true
SYNC_IMAGES=true
# unpublish | ignore
INACTIVE_ACTION=unpublish
MAX_CONCURRENCY=3

# Optionales Override des Feld-Mappings (JSON, siehe README)
WEBFLOW_FIELD_MAP_JSON=

# Nur build-zeitig: muss dem Webflow-Cloud-Mount-Path entsprechen
BASE_PATH=/app
